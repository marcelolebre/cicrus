{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Cicrus design tokens — W3C DTCG format. Machine-readable mirror of src/tokens.css. Two-tier: primitives feed semantic aliases. Dark is the default theme; light is a parallel first-class theme, not a derivation.",
  "$metadata": {
    "name": "Cicrus",
    "version": "2.0.0",
    "modes": ["dark", "light"]
  },

  "font": {
    "$type": "fontFamily",
    "display": { "$value": ["Doto", "Space Mono", "monospace"], "$description": "Hero numbers & wordmark. 36px+ only, never body." },
    "body":    { "$value": ["Space Grotesk", "system-ui", "sans-serif"], "$description": "Body copy, UI labels, data." },
    "mono":    { "$value": ["Space Mono", "JetBrains Mono", "SF Mono", "monospace"], "$description": "ALL-CAPS instrument labels, numbers, code." }
  },

  "fontSize": {
    "$type": "dimension",
    "display-xl": { "$value": "72px" },
    "display-lg": { "$value": "48px" },
    "display-md": { "$value": "36px" },
    "heading":    { "$value": "24px" },
    "subheading": { "$value": "18px" },
    "body":       { "$value": "16px" },
    "body-sm":    { "$value": "14px" },
    "caption":    { "$value": "12px" },
    "label":      { "$value": "11px" },
    "label-xs":   { "$value": "10px" }
  },

  "space": {
    "$type": "dimension",
    "$description": "8px base grid. T-shirt sizes.",
    "2xs": { "$value": "2px" },
    "xs":  { "$value": "4px" },
    "sm":  { "$value": "8px" },
    "md":  { "$value": "16px" },
    "lg":  { "$value": "24px" },
    "xl":  { "$value": "32px" },
    "2xl": { "$value": "48px" },
    "3xl": { "$value": "64px" },
    "4xl": { "$value": "96px" }
  },

  "radius": {
    "$type": "dimension",
    "tech": { "$value": "4px", "$description": "Alert banners, modals, code chips." },
    "card": { "$value": "8px", "$description": "Cards, panels." },
    "pill": { "$value": "999px", "$description": "Badges, buttons, toggles." }
  },

  "color": {
    "$description": "Each semantic role resolves to a different primitive per mode. Contrast ratios are WCAG 2.1 against the mode's --black.",
    "accent":      { "$type": "color", "$value": "#D71921", "$description": "Signal red. Interrupt only — errors, destructive, the one accent moment per screen. Identical across modes." },
    "success":     { "$type": "color", "$value": { "dark": "#4A9E5C", "light": "#2E7D32" }, "$description": "Done, healthy, in-range." },
    "warning":     { "$type": "color", "$value": { "dark": "#D4A843", "light": "#B59A5A" }, "$description": "Pending, degraded, attention." },
    "interactive": { "$type": "color", "$value": { "dark": "#5B9BF6", "light": "#007AFF" }, "$description": "Links, info, tappable text — not buttons." },

    "black":          { "$type": "color", "$value": { "dark": "#000000", "light": "#F5F5F5" }, "$description": "Page background. OLED black / warm off-white." },
    "surface":        { "$type": "color", "$value": { "dark": "#111111", "light": "#FFFFFF" }, "$description": "Elevated surfaces, cards, nav." },
    "surface-raised": { "$type": "color", "$value": { "dark": "#1A1A1A", "light": "#F0F0F0" }, "$description": "Secondary elevation, item cards, dropdowns." },
    "border":         { "$type": "color", "$value": { "dark": "#2E2E2E", "light": "#D9D9D9" }, "$description": "Decorative hairlines." },
    "border-visible": { "$type": "color", "$value": { "dark": "#555555", "light": "#9E9E9E" }, "$description": "Intentional borders, focus, input underline. ~3:1." },

    "text-disabled":  { "$type": "color", "$value": { "dark": "#8F8F8F", "light": "#737373" }, "$description": "Tertiary meta, placeholders. ~4.6:1." },
    "text-secondary": { "$type": "color", "$value": { "dark": "#B8B8B8", "light": "#595959" }, "$description": "Labels, captions, descriptions. ~7:1." },
    "text-primary":   { "$type": "color", "$value": { "dark": "#E8E8E8", "light": "#1A1A1A" }, "$description": "Body copy, data values. ~16.5:1." },
    "text-display":   { "$type": "color", "$value": { "dark": "#FFFFFF", "light": "#000000" }, "$description": "Headlines, hero numbers, active nav. 21:1." }
  },

  "motion": {
    "$type": "cubicBezier",
    "ease": { "$value": [0.25, 0.1, 0.25, 1], "$description": "Percussive ease-out. No spring, no bounce." },
    "duration": {
      "$type": "duration",
      "micro":  { "$value": "150ms" },
      "switch": { "$value": "300ms" },
      "view":   { "$value": "400ms" }
    }
  }
}
